# .env.example
# 프로젝트를 로컬에서 구동할 때 필요한 환경 변수 템플릿입니다.
# 이 파일을 복사하여 .env 파일을 생성한 후 실제 값을 입력하세요.

# API Keys (예시: OpenAI를 사용할 경우, 현재는 Ollama 위주이므로 Optional)
# OPENAI_API_KEY=your_openai_api_key_here

# PubMed API
PUBMED_EMAIL=your_email@example.com
PUBMED_TOOL_NAME=SystematicReviewerAI

# Database or Storage paths
DATA_DIR=./data
MODEL_DIR=./models

# App Settings
STREAMLIT_SERVER_PORT=8502
OLLAMA_HOST=http://localhost:11434
GROBID_URL=http://localhost:8070
